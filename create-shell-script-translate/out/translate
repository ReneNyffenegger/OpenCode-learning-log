#!/usr/bin/env bash
set -euo pipefail

if ! command -v curl >/dev/null 2>&1; then
  echo "curl is required" >&2
  exit 1
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "jq is required" >&2
  exit 1
fi

if [ -z "${MOONSHOT_API_KEY:-}" ]; then
  echo "MOONSHOT_API_KEY is not set" >&2
  exit 1
fi

if [ "$#" -eq 0 ]; then
  echo "Usage: $0 <text to translate>" >&2
  exit 1
fi

text="$*"

payload=$(jq -n --arg text "$text" '{
  model: "kimi-k2.5",
  messages: [
    {
      role: "system",
      content: "Translate text between English and German based on the source language. If the provided text is English, translate it to German. For any other source language, translate the text to English. Preserve the original meaning, tone, and formatting; reply with the translation only."
    },
    {
      role: "user",
      content: $text
    }
  ]
}')

response=$(curl -sS https://api.moonshot.ai/v1/chat/completions \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer ${MOONSHOT_API_KEY}" \
  -d "$payload")

echo "$response" | jq -e -r '.choices[0].message.content' || {
  echo "$response" >&2
  exit 1
}
